Usage: menu [OPTION...] [ARG1] [ARG2] [ARG3] [ARG4] [ARG5]
C-Menu

  -D, --f_dump_config        dump configuration
  -W, --f_write_config       write configuration
  -a, --minitrc=file_spec    configuration file spec
  -k, --parent_cmd           parent command
  -C, --cols=number          width in columns
  -L, --lines=number         height in lines
  -n, --select_max=number    number of selections
  -o, --out_spec=file_spec   output spec
  -X, --begx=number          begin on column
  -Y, --begy=number          begin on line
  -A, --cmd_all=file_spec    view cmd, all files
  -c, --cmd=file_spec        view cmd, first file
  -d, --mapp_spec=file_spec  description spec
  -H, --help_spec=file_spec  help spec
  -i, --in_spec=file_spec    input spec
  -R, --receiver_cmd=file_spec   execute receiver of piped output
  -S, --provider_cmd=file_spec   execute provider of piped input
  -T, --title=text           Window title
  -e, --f_erase_remainder    erase remainder of line on enter
  -j, --f_strip_ansi         always strip ansi when writing
  -s, --f_squeeze            squeeze multiple blank lines
  -x, --f_ignore_case        ignore case in search
  -f, --fill_char=char       field fill_char
  -N, --f_ln                 line numbers in view
  -t, --tab_stop=number      number of spaces per tab
  -u, --brackets=text        brackets around fields
      --bg_clr_x=hex_clr     background color
      --bo_clr_x=hex_clr     border color
      --fg_clr_x=hex_clr     foreground color
      --ln__bg_clr_x=hex_clr line number background
      --ln_clr_x=hex_clr     line number color
      --blue_gamma=float     blue_gamma (View)
      --gray_gamma=float     gray gamma (View)
      --green_gamma=float    green gamma (View)
      --red_gamma=float      red gamma (View)
      --bblack=hex_clr       bright black ([38;2;0;0;0m[48;2;127;127;127m#7f7f7f[0m)
      --bblue=hex_clr        bright blue ([38;2;0;0;0m[48;2;0;207;255m#00cfFF[0m)
      --bcyan=hex_clr        bright cyan ([38;2;0;0;0m[48;2;0;255;255m#00FFFF[0m)
      --bgreen=hex_clr       bright green ([38;2;0;0;0m[48;2;0;255;127m#00FF7f[0m)
      --black=hex_clr        black ([38;2;255;255;255m[48;2;0;0;0m#000000[0m)
      --blue=hex_clr         blue ([38;2;255;255;255m[48;2;0;0;255m#0000FF[0m)
      --bmagenta=hex_clr     bright magenta ([38;2;255;255;255m[48;2;255;0;255m#FF00FF[0m)
      --bred=hex_clr         bright red ([38;2;0;0;0m[48;2;255;55;55m#FF3737[0m)
      --bwhite=hex_clr       bright white ([38;2;0;0;0m[48;2;255;255;255m#FFFFFF[0m)
      --byellow=hex_clr      bright yellow ([38;2;0;0;0m[48;2;255;239;0m#FFeF00[0m)
      --cyan=hex_clr         cyan ([38;2;0;0;0m[48;2;0;223;223m#00dfdf[0m)
      --editor=text          default editor
      --green=hex_clr        green ([38;2;0;0;0m[48;2;0;207;0m#00cf00[0m)
      --magenta=hex_clr      magenta ([38;2;255;255;255m[48;2;159;0;159m#9f009f[0m)
      --red=hex_clr          red ([38;2;255;255;255m[48;2;191;0;0m#bf0000[0m)
      --white=hex_clr        white ([38;2;0;0;0m[48;2;208;208;208m#d0d0d0[0m)
      --yellow=hex_clr       yellow ([38;2;0;0;0m[48;2;239;191;0m#efbf00[0m)
      --mapp_data=directory  data directory
      --mapp_help=directory  help directory
      --mapp_home=directory  home directory
      --mapp_msrc=directory  source directory
      --mapp_user=directory  user directory
  -h, --help                 display help

Mandatory or optional arguments to long options are also mandatory or optional
for any corresponding short options.

