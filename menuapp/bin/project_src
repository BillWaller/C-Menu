#!/bin/bash
# @name project_src
# @brief This script lists source files in a directory specified by the CMENU_SRC
# environment variable.

if [ -d "$CMENU_SRC" ]; then
    cd "$CMENU_SRC"
else
    echo "Error: CMENU_SRC environment variable is not set or points to a non-existent directory."
    exit 1
fi
lf -d 5 "$CMENU_SRC" '.*\.(h|c|rs|sh|cpp)$' | sort
